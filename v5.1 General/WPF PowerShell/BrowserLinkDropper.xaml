<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Browser Link Dropper - Multi-Target"
        Height="900"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <StackPanel Margin="15">
            <TextBlock Text="Drag and drop links from Edge, Firefox, or Brave browsers"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#333333"
                       Margin="0,0,0,15" />
            
            <!-- Browser Info Section -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Edge Info -->
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Edge Active Tab" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <TextBox Name="EdgeTextBox"
                             Height="60"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Background="White"
                             BorderThickness="2"
                             BorderBrush="#CCCCCC"
                             Margin="0,0,0,8"
                             Foreground="#333333"
                             FontFamily="Courier New"
                             FontSize="10" />
                    <Button Name="EdgeRefreshButton" Content="Refresh" Width="80" Background="#2196F3" Foreground="White" FontWeight="Bold" />
                </StackPanel>
                
                <!-- Brave Info -->
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Brave Active Tab" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <TextBox Name="BraveTextBox"
                             Height="60"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Background="White"
                             BorderThickness="2"
                             BorderBrush="#CCCCCC"
                             Margin="0,0,0,8"
                             Foreground="#333333"
                             FontFamily="Courier New"
                             FontSize="10" />
                    <Button Name="BraveRefreshButton" Content="Refresh" Width="80" Background="#2196F3" Foreground="White" FontWeight="Bold" />
                </StackPanel>
            </Grid>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 1, Column 1 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="Drop Target 1" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox1"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton1" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton1" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 1, Column 2 -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Drop Target 2" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox2"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton2" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton2" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 1, Column 3 -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                    <TextBlock Text="Drop Target 3" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox3"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton3" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton3" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 1, Column 4 -->
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="5">
                    <TextBlock Text="Drop Target 4" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox4"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton4" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton4" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 2, Column 1 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Drop Target 5" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox5"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton5" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton5" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 2, Column 2 -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Drop Target 6" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox6"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton6" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton6" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 2, Column 3 -->
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="5">
                    <TextBlock Text="Drop Target 7" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox7"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton7" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton7" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 2, Column 4 -->
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="5">
                    <TextBlock Text="Drop Target 8" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" />
                    <RichTextBox Name="RichTextBox8"
                                 Height="200"
                                 Background="White"
                                 BorderThickness="2"
                                 BorderBrush="#CCCCCC"
                                 AllowDrop="True"
                                 Margin="0,0,0,8"
                                 Foreground="#333333"
                                 FontFamily="Courier New"
                                 FontSize="10" />
                    <StackPanel Orientation="Horizontal" Height="35">
                        <Button Name="CopyButton8" Content="Copy" Width="70" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" />
                        <Button Name="ClearButton8" Content="Clear" Width="70" Background="#F44336" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
